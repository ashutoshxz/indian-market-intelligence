# ================================
# Indian Market Intelligence Platform
# .env.example
# Copy this file to .env and fill in your values
# ================================

# ---- App ----
NODE_ENV=development
APP_NAME=Indian Market Intelligence Platform
APP_URL=http://localhost:3000

# ---- Backend Server ----
BACKEND_PORT=5000
BACKEND_HOST=localhost

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000
VITE_APP_NAME=Indian Market Intelligence

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/market_intelligence
DB_HOST=localhost
DB_PORT=5432
DB_NAME=market_intelligence
DB_USER=postgres
DB_PASSWORD=your_password_here

# ---- Redis (Caching & Pub/Sub) ----
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- AI Service ----
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your_ai_service_key_here

# ---- Ingestion Service ----
INGESTION_SERVICE_URL=http://localhost:8001
INGESTION_INTERVAL_SECONDS=60

# ---- NSE / BSE Market Data ----
NSE_API_BASE_URL=https://www.nseindia.com/api
BSE_API_BASE_URL=https://api.bseindia.com
MARKET_DATA_API_KEY=your_market_data_key_here

# ---- RBI / SEBI Feeds ----
RBI_FEED_URL=https://www.rbi.org.in/rss
SEBI_FEED_URL=https://www.sebi.gov.in/rss
POLICY_FEED_INTERVAL_SECONDS=300

# ---- News API ----
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_BASE_URL=https://newsapi.org/v2

# ---- Macro Data ----
FRED_API_KEY=your_fred_api_key_here
WORLD_BANK_API_URL=https://api.worldbank.org/v2

# ---- JWT Auth ----
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d

# ---- CORS ----
CORS_ORIGIN=http://localhost:5173

# ---- Email (Alerts / Notifications) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@marketintelligence.in

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- AI / NLP (OpenAI or HuggingFace) ----
OPENAI_API_KEY=your_openai_key_here
HUGGINGFACE_API_KEY=your_huggingface_key_here
DEFAULT_AI_MODEL=gpt-4o-mini

# ---- Logging ----
LOG_LEVEL=debug
LOG_FORMAT=combined
